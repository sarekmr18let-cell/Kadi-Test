# Telegram
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_TG_ID=your_telegram_user_id_here
BOT_USERNAME=your_bot_username_here
INTERNAL_BOT_SECRET=
P2P_WEBHOOK_SECRET=generate_another_random_string_32_chars_min
P2P_TEST_MODE=false
P2P_PAYMENT_TTL_MINUTES=5
WALLET_TOPUP_MIN_AMOUNT=1000
WALLET_TOPUP_MAX_AMOUNT=5000000

# Bot Support (optional)
SUPPORT_USERNAME=your_support_username
SUPPORT_EMAIL=support@yourdomain.com

# Database
POSTGRES_USER=tgbot
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=tgbot

# JWT
JWT_SECRET=generate_random_string_32_chars_min

# MooGold API credentials
MOOGOLD_PARTNER_ID=your_moogold_partner_id
MOOGOLD_SECRET_KEY=your_moogold_secret_key
MOOGOLD_AUTO_FULFILL_ENABLED=true
MOOGOLD_DEFAULT_ORDER_CATEGORY=1
MOOGOLD_TEST_MODE=false

# URLs
WEBAPP_URL=https://your-domain.com
CALLBACK_BASE_URL=https://your-domain.com/api/webhook

FRONTEND_URL=https://your-domain.com

# P2P auto parser / Telegram Business bridge
# Backend and bot containers must use the same P2P_WEBHOOK_SECRET value.
# Use a long random string. Do not share it publicly.
